<?xml version="1.0" encoding="UTF-8"?>
<CarTestFlow name="Parser Demo Flow" version="1.0">
  <ImageResources>
    <Image id="home_icon" path="./images/home.png" description="Home icon" />
    <Image id="ac_icon" path="./images/ac.png" description="AC icon" />
    <Image id="ac_panel" path="./images/ac_panel.png" description="AC panel" />
    <Image id="temp_up" path="./images/temp_up.png" description="Temperature up" />
  </ImageResources>

  <TestCase id="TC_PARSE_001" name="Parser integration demo">
    <Description>Covers all supported operation definitions in one flow.</Description>
    <Steps>
      <Step id="1" name="Open AC">
        <Action type="click_image" imageId="ac_icon" onPageImageId="home_icon" />
        <Action type="wait" duration="1000" />
        <Assert type="verify_image" imageId="ac_panel" timeout="5000" expectedState="visible" />
        <Assert type="verify_image_present" imageId="ac_panel" timeout="3000" />
      </Step>

      <Step id="2" name="Coordinate and swipe">
        <Action type="click_coordinate" x="300" y="420" />
        <Action type="wait" duration="300" />
        <Action type="swipe" startX="300" startY="420" endX="700" endY="420" duration="600" />
        <Action type="wait" duration="300" />
      </Step>

      <Loop times="2" name="Increase temperature loop">
        <Step id="3.${iteration}" name="Increase iteration ${iteration}">
          <Action type="click_image" imageId="temp_up" onPageImageId="ac_panel" />
          <Action type="wait" duration="300" />
          <Assert type="verify_text" region="100,120,300,80" text="TEMP" timeout="2000" />
        </Step>
      </Loop>

      <Step id="4" name="Back home">
        <Action type="press_key" key="HOME" />
        <Action type="wait" duration="500" />
        <Assert type="verify_image" imageId="home_icon" onPageImageId="home_icon" timeout="5000" expectedState="visible" />
        <Assert type="verify_page" pageName="home_page" pageImageId="home_icon" timeout="3000" />
      </Step>
    </Steps>
  </TestCase>
</CarTestFlow>
