  <TestCase id="TC_FLOW_001" name="home-music-home-app-home">
    <Description>
      home page -> click music_btn -> verify music page -> click home_btn -> verify home page
      -> click app_btn -> verify app page -> click home_btn -> verify home page
    </Description>
    <Steps>
      <Step id="1" name="Initial home">
        <Assert type="verify_image" imageId="home_page" expectedState="visible" timeout="5000" />
      </Step>

      <Step id="2" name="Enter music">
        <Action type="click_image" imageId="music_btn" onPageImageId="home_page" />
        <Action type="wait" duration="1000" />
        <Assert type="verify_image" imageId="music_page" expectedState="visible" timeout="5000" />
      </Step>

      <Step id="3" name="Back to home from music">
        <Action type="click_image" imageId="home_btn" onPageImageId="music_page" />
        <Action type="wait" duration="1000" />
        <Assert type="verify_image" imageId="home_page" expectedState="visible" timeout="5000" />
      </Step>

      <Step id="4" name="Enter appCenter">
        <Action type="click_image" imageId="app_btn" onPageImageId="home_page" />
        <Action type="wait" duration="1000" />
        <Assert type="verify_image" imageId="app_page" expectedState="visible" timeout="5000" />
      </Step>

      <Step id="5" name="Back to home from appCenter">
        <Action type="click_image" imageId="home_btn" onPageImageId="app_page" />
        <Action type="wait" duration="1000" />
        <Assert type="verify_image" imageId="home_page" expectedState="visible" timeout="5000" />
      </Step>
    </Steps>
  </TestCase>
</CarTestFlow>
